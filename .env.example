REMNAWAVE_BASE_URL=https://vpn.example.com
REMNAWAVE_API_TOKEN=your-api-token-here

# Optional: API key for Caddy reverse proxy with custom path
# See: https://docs.remnawave.com/docs/security/caddy-with-custom-path/
# REMNAWAVE_API_KEY=your-caddy-api-key

# Optional: Cookie for panels protected by reverse proxy cookie auth (e.g. remnawave-reverse-proxy)
# REMNAWAVE_COOKIE=SECRET_KEY=SECRET_KEY

# Optional: enable readonly mode (only read/list operations, no create/update/delete)
# REMNAWAVE_READONLY=true
