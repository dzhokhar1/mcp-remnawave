REMNAWAVE_BASE_URL=https://vpn.example.com

# WARNING: REMNAWAVE_API_TOKEN is a FULL-ADMIN panel credential. Anyone holding it
# (or any process that can read this file, `docker inspect`, or /proc/<pid>/environ)
# can delete every user, mint new admin tokens, restart nodes, and read all
# subscriptions. Protect it: `chmod 600 .env`, use the most limited token the panel
# offers, and rotate it regularly. https:// is required (loopback http is allowed).
REMNAWAVE_API_TOKEN=your-api-token-here

# Optional: API key for Caddy reverse proxy with custom path
# See: https://docs.remnawave.com/docs/security/caddy-with-custom-path/
# REMNAWAVE_API_KEY=your-caddy-api-key

# Optional: Cookie for panels protected by reverse proxy cookie auth (e.g. remnawave-reverse-proxy)
# REMNAWAVE_COOKIE=SECRET_KEY=SECRET_KEY

# --- Capability flags (all default to the SAFE value) ---
# The server is READ-ONLY by default and every high-risk capability is OFF. Enable
# only what a given deployment actually needs. `readonly` is also enforced at the
# HTTP layer (non-GET requests are blocked), not just by hiding tools.

# Master switch. true = only read/list tools; false = enable ordinary create/update/delete.
# REMNAWAVE_READONLY=true

# Below flags only take effect when REMNAWAVE_READONLY=false (unless noted).

# Bulk / whole-fleet destructive ops (bulk delete, delete-by-status, *_bulk_all_*,
# nodes_restart_all, hosts_bulk_*). One call can affect every user/node.
# REMNAWAVE_ALLOW_DESTRUCTIVE=false

# Create/delete panel API tokens (mints durable admin credentials; can lock you out).
# REMNAWAVE_ALLOW_TOKEN_ADMIN=false

# Update panel settings (webhook/notification targets, auth/HWID toggles, etc.).
# REMNAWAVE_ALLOW_SETTINGS_WRITE=false

# Generate/return secret key material: node SECRET_KEY (keygen) and X25519 private
# keys. Takes effect regardless of readonly (these are GETs that return secrets).
# REMNAWAVE_ALLOW_KEYGEN=false

# Export live VPN connection credentials to the model: raw subscription configs and
# connection keys (vless://, ss://, trojan:// URIs). Takes effect regardless of readonly.
# REMNAWAVE_ALLOW_SECRETS_EXPORT=false

# Fetch/reveal real client IP addresses (deanonymizes VPN users) via IP-control jobs.
# REMNAWAVE_ALLOW_PII=false

# Execute node plugins on the fleet and truncate torrent-blocker reports.
# REMNAWAVE_ALLOW_PLUGIN_EXEC=false

# Allow a non-loopback http:// base URL (INSECURE — sends the admin token in cleartext).
# REMNAWAVE_ALLOW_INSECURE_HTTP=false
